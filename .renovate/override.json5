{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Disable digest-only updates for docker images",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      enabled: false,
    },
    {
      description: "Use semver prerelease handling for RustFS image tags",
      matchDatasources: ["docker"],
      matchPackageNames: ["docker.io/rustfs/rustfs"],
      versioning: "semver",
      ignoreUnstable: false,
      respectLatest: false,
      allowedVersions: "/^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.]+)?$/",
    },
    {
      description: "Pin Cloudflare Terraform provider to 4.52.x (hold off on v5)",
      matchDatasources: ["terraform-provider"],
      matchDepNames: ["cloudflare"],
      matchDepTypes: ["required_provider"],
      allowedVersions: "<4.53",
    },
  ],
}
